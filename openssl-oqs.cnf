openssl_conf = openssl_init

[openssl_init]
providers = provider_sect
ssl_conf = ssl_module

[provider_sect]
default = default_sect
oqsprovider = oqs_sect

[default_sect]
activate = 1

[oqs_sect]
activate = 1

[ssl_module]
system_default = tls_system_default

[tls_system_default]
Groups = X25519MLKEM768:mlkem768:x25519:prime256v1:x448:secp521r1:secp384r1
